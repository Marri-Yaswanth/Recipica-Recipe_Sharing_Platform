{
  "name": "recipe-platform-combined",
  "version": "1.0.0",
  "description": "Combined recipe sharing platform with React frontend and Express backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd ../frontend && npm start",
    "build": "cd ../frontend && npm install && npm run build",
    "concurrently": "concurrently \"npm run dev\" \"npm run client\"",
    "heroku-postbuild": "npm run build"
  },
  "engines": {
    "node": "18.x",
    "npm": "9.x"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.9.15",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-instagram": "^1.0.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "nodemon": "^3.0.2"
  }
}
